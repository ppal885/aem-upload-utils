# Server port (default: 3000)
PORT=3000

# API key for authentication (leave empty to disable auth in dev mode)
API_KEY=

# CORS origin (default: * allows all)
CORS_ORIGIN=*

# Log level: error, warn, info, debug (default: info)
LOG_LEVEL=info

# Log file path (leave empty for console-only logging)
# Example: LOG_FILE=server.log
LOG_FILE=

# Restrict file browsing to specific directories (comma-separated, empty = unrestricted)
# Example: BROWSE_ROOTS=C:\content,D:\assets
BROWSE_ROOTS=

# Max upload size for browser uploads in bytes (default: 5GB)
MAX_UPLOAD_SIZE=5368709120

# Max upload history entries (default: 100)
# MAX_HISTORY=100

# SSE replay buffer cap (default: 10000)
# SSE_EVENT_CAP=10000

# SSE keep-alive ping interval in ms (default: 15000)
# SSE_KEEPALIVE_MS=15000

# File batch queue cap — prevents unbounded memory growth (default: 5000)
# FILE_BATCH_QUEUE_CAP=5000

# File batch flush interval in ms (default: 150)
# FILE_BATCH_INTERVAL_MS=150

# Max file errors to track per upload session (default: 1000)
# FILE_ERRORS_CAP=1000

# Session reaper interval in ms (default: 120000 = 2 min)
# SESSION_REAPER_INTERVAL_MS=120000

# Memory monitor interval in ms (default: 300000 = 5 min)
# MEMORY_MONITOR_INTERVAL_MS=300000

# Graceful shutdown timeout in ms (default: 10000)
# SHUTDOWN_TIMEOUT_MS=10000

# Allow self-signed certs for localhost HTTPS (e.g. https://localhost:4502). Dev only.
# AEM_ALLOW_SELF_SIGNED=1

# CLI upload settings (for migrate-to-aem.js)
AEM_URL=
AEM_DAM_PATH=
AEM_LOCAL_PATH=
AEM_USERNAME=
AEM_PASSWORD=
AEM_MAX_CONCURRENT=20
AEM_MAX_FILES=50000
